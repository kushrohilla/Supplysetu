{
  "expo": {
    "name": "SupplySetu",
    "slug": "supplysetu-mobile",
    "scheme": "supplysetu",
    "version": "0.1.0",
    "orientation": "portrait",
    "platforms": [
      "android"
    ],
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "com.supplysetu.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#F3E9D8"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ],
          "data": [
            {
              "scheme": "https",
              "host": "app.domain.com",
              "pathPrefix": "/join"
            }
          ]
        }
      ]
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}
