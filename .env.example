NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:4173,http://127.0.0.1:4173,http://localhost:3000,http://127.0.0.1:3000,http://localhost:8000,http://127.0.0.1:8000,http://localhost:8081
APP_REGION=ap-south-1
TRUST_PROXY=false
SHUTDOWN_TIMEOUT_MS=10000
LOG_LEVEL=info
JWT_SECRET=replace-with-a-strong-secret-key
JWT_REFRESH_SECRET=replace-with-a-strong-refresh-secret
JWT_EXPIRES_IN=1d
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/supplysetu
DB_SSL=false
NOTIFICATIONS_SMS_PROVIDER=disabled
NOTIFICATIONS_SMS_SENDER_ID=
NOTIFICATIONS_SMS_API_KEY=
NOTIFICATIONS_WHATSAPP_PROVIDER=disabled
NOTIFICATIONS_WHATSAPP_SENDER_ID=
NOTIFICATIONS_WHATSAPP_API_KEY=
NOTIFICATIONS_SCHEDULER_ENABLED=true
NOTIFICATIONS_INACTIVITY_CRON=0 10 * * *
NOTIFICATIONS_INACTIVITY_DAYS=7
NOTIFICATIONS_INACTIVITY_COOLDOWN_HOURS=72
